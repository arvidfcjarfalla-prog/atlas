[
  {
    "id": "good-choropleth",
    "label": "Well-formed choropleth with all fields",
    "expectedScore": 90,
    "manifest": {
      "id": "eval-choropleth",
      "title": "Population Density by Country",
      "description": "Choropleth showing population density across Europe.",
      "theme": "decision",
      "defaultCenter": [50, 10],
      "defaultZoom": 4,
      "defaultBounds": [[35, -10], [65, 30]],
      "layers": [{
        "id": "density",
        "kind": "zone",
        "label": "Density",
        "sourceType": "geojson-static",
        "geometryType": "polygon",
        "style": {
          "markerShape": "circle",
          "mapFamily": "choropleth",
          "colorField": "density",
          "classification": { "method": "quantile", "classes": 5 },
          "color": { "scheme": "blues", "colorblindSafe": true },
          "normalization": { "field": "area_km2", "method": "per-area" },
          "fillOpacity": 0.85,
          "strokeColor": "rgba(255,255,255,0.4)",
          "strokeWidth": 1
        },
        "legend": { "title": "Density (per km²)", "type": "gradient" },
        "interaction": {
          "tooltipFields": ["name", "density", "population"],
          "clickBehavior": "popup",
          "hoverEffect": "highlight"
        }
      }]
    },
    "geojson": {
      "type": "FeatureCollection",
      "features": [
        { "type": "Feature", "geometry": { "type": "Polygon", "coordinates": [[[-5,42],[3,42],[3,51],[-5,51],[-5,42]]] }, "properties": { "name": "France", "density": 119, "population": 67390000, "area_km2": 551695 } },
        { "type": "Feature", "geometry": { "type": "Polygon", "coordinates": [[[5,47],[15,47],[15,55],[5,55],[5,47]]] }, "properties": { "name": "Germany", "density": 240, "population": 83200000, "area_km2": 357588 } },
        { "type": "Feature", "geometry": { "type": "Polygon", "coordinates": [[[6,36],[18,36],[18,47],[6,47],[6,36]]] }, "properties": { "name": "Italy", "density": 206, "population": 59550000, "area_km2": 301340 } },
        { "type": "Feature", "geometry": { "type": "Polygon", "coordinates": [[[-10,36],[4,36],[4,44],[-10,44],[-10,36]]] }, "properties": { "name": "Spain", "density": 94, "population": 47350000, "area_km2": 505990 } },
        { "type": "Feature", "geometry": { "type": "Polygon", "coordinates": [[[14,49],[24,49],[24,55],[14,55],[14,49]]] }, "properties": { "name": "Poland", "density": 124, "population": 37750000, "area_km2": 312696 } }
      ]
    }
  },
  {
