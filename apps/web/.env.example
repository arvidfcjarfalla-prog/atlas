# ─── Required ─────────────────────────────────────────────
# Anthropic API key for Claude (map generation, editing, intent classification)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase project URL and keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Optional ─────────────────────────────────────────────
# Google Data Commons API key (subnational statistics)
# DATA_COMMONS_API_KEY=

# Google Gemini API key (alternative utility model)
# GOOGLE_GENERATIVE_AI_API_KEY=

# Utility model: "anthropic" (default, uses Haiku) or "google" (uses Gemini Flash)
# AI_UTILITY_MODEL=anthropic

# Disable web search in development (saves API credits)
# ATLAS_DISABLE_WEB_SEARCH=true

# Cron job secret (protects /api/cron/* endpoints)
# CRON_SECRET=your-random-secret

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=
